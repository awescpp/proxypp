{
  "type": "commonjs",
  "scripts": {
    "co": "cz",
    "prepare": "simple-git-hooks",
    "lint:commit": "commitlint --edit"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "commitizen": "^4.3.1",
    "cz-git": "^1.13.1",
    "simple-git-hooks": "^2.13.1"
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-git"
    }
  },
  "simple-git-hooks": {
    "commit-msg": "npx --no -- commitlint --edit $1"
  }
}
